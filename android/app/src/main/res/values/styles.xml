<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- v1.20: 라이트 모드 OS 라도 facing 앱은 항상 다크. parent Theme.Black 강제. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- Android 12+ Splash Screen API: launcher 아이콘 자동 노출 차단 (Flutter 기본 로고 숨김). -->
        <item name="android:windowSplashScreenBackground">@color/facing_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_empty</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/facing_bg</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/facing_bg</item>
    </style>
</resources>
